block_date() {
  fmt="$1"
  [ -z "$fmt" ] && fmt="%a %Y-%m-%d"
  echo "σΑÉ° $(date "+$fmt")"
}

block_time() {
  fmt="$1"
  [ -z "$fmt" ] && fmt="%I:%M %p"
  echo "σΑΞî $(date "+$fmt")"
}

_vol_amixer_by_type() {
  type="$1"
  [ -z "$type" ] && return
  amixer get "$type" | while read -r line; do
    case "$line" in
    *Playback*%*off* | *Capture*%*off*)
      echo mute
      break
      ;;
    *Playback*%* | *Capture*%*)
      vol="${line%%"%]"*}"
      vol="${vol##*"["}"
      echo "$vol"
      break
      ;;
    esac
  done
}

_vol_amixer() {
  _vol_amixer_by_type "Master"
}

_mic_amixer() {
  _vol_amixer_by_type "Capture"
}

_vol_pactl_by_type() {
  type="$1"
  device="@DEFAULT_$(echo "$type" | tr '[:lower:]' '[:upper:]')@"
  mute="$(pactl get-"$type"-mute "$device")"

  if [ "${mute##* }" = "yes" ]; then
    echo mute
    return
  fi

  pactl get-"$type"-volume "$device" | while read -r line; do
    case "$line" in
    "Volume"*)
      lvl="${line%%%*}"
      lvl="${lvl##* }"
      echo "$lvl"
      break
      ;;
    esac
  done
}

_vol_pactl() {
  _vol_pactl_by_type "sink"
}

_mic_pactl() {
  _vol_pactl_by_type "source"
}

_vol_wpctl_by_type() {
  type="$1"
  [ -z "$type" ] && return
  wpctl get-volume "$type" | while read -r line; do
    case "$line" in
    "Volume"*"[MUTED]")
      echo mute
      break
      ;;
    "Volume: 1."*)
      lvl="${line##* }"
      echo "${lvl%%.*}${lvl##*.}"
      break
      ;;
    "Volume"*)
      lvl="${line##*.}"
      echo "${lvl#0}"
      break
      ;;
    esac
  done
}

_vol_wpctl() {
  _vol_wpctl_by_type "@DEFAULT_SINK@"
}

_mic_wpctl() {
  _vol_wpctl_by_type "@DEFAULT_SOURCE@"
}

