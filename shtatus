_cpu_linux() {
  while read -r cpu u1 n1 s1 i1 w1 irq1 sirq1 st1 _; do
    break
  done </proc/stat
  sleep 0.3
  while read -r cpu u2 n2 s2 i2 w2 irq2 sirq2 st2 _; do
    break
  done </proc/stat

  idle1=$((i1 + w1))
  idle2=$((i2 + w2))
  total1=$((u1 + n1 + s1 + i1 + w1 + irq1 + sirq1 + st1))
  total2=$((u2 + n2 + s2 + i2 + w2 + irq2 + sirq2 + st2))
  totald=$((total2 - total1))
  idled=$((idle2 - idle1))

  [ "$totald" -gt 0 ] || return

  busyd=$((totald - idled))
  pct=$(((busyd * 100 + totald / 2) / totald))

  if [ "$pct" -gt 99 ]; then
    pct=99
  fi

  printf '’Æ╝ %02d%%\n' "$pct"
}

block_cpu() {
  case "$os" in
  linux) _cpu_linux ;;
  esac
}

_ram_linux() {
  total=""
  avail=""
  while IFS=" :" read -r key val _; do
    case "$key" in
    MemTotal) total=$val ;;
    MemAvailable) avail=$val ;;
    esac
  done </proc/meminfo

  if [ -z "$total" ] || [ -z "$avail" ]; then
    return
  fi

  used=$((total - avail))
  whole=$((used / 1048576))
  tenths=$(((used % 1048576) * 10 / 1048576))
  printf 'Ņē” %02d.%sG\n' "$whole" "$tenths"
}

block_ram() {
  case "$os" in
  linux) _ram_linux ;;
  esac
}

