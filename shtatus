# Choose what blocks to print
: "${SHTATUS_BLOCKS:=vol cpu time date}"

# Interval in seconds
# (note: total loop time includes both this
# delay and the time each block takes to run).
: "${SHTATUS_INTERVAL:=0.5}"

# Separator character
: "${SHTATUS_SEPARATOR:=   }"

_has() {
  command -v "$1" >/dev/null 2>&1
}

_is_running() {
  pattern="$1"

  if [ -z "$pattern" ]; then
    return 1
  fi

  case "$os" in
  linux)
    for proc in $(ps -A -o comm= 2>/dev/null); do
      case "$proc" in
      $pattern) return 0 ;;
      esac
    done
    ;;
  freebsd | openbsd)
    for proc in $(ps -ax -o comm= 2>/dev/null); do
      case "$proc" in
      $pattern) return 0 ;;
      esac
    done
    ;;
  esac

  return 1
}

_bat_status() {
  status=""
  for b in /sys/class/power_supply/BAT*; do
    if [ -d "$b" ]; then
      while read -r line; do
        echo "$line"
        break
      done <"$b/status"
      break
    fi
  done
}

_bat_val() {
  col="$1"
  total=0
  batteries=0
  for battery in /sys/class/power_supply/BAT*; do
    if [ -r "$battery" ]; then
      while read -r line; do
        value="$line"
      done <"$battery/$col"
      total=$((value + total))
      batteries=$((batteries + 1))
    fi
  done
  [ "$batteries" -eq 0 ] && return
  echo "$((total / batteries))"
}

