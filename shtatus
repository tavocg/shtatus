#!/bin/sh
# shellcheck shell=sh

# Choose what blocks to print
: "${SHTATUS_BLOCKS:=volume volmic cpu ram net bat kb time date}"

# Interval in seconds
# The time to complete blocks is added to this interval,
# so this is not exact.
: "${SHTATUS_INTERVAL:=0.5}"

# Separator character
: "${SHTATUS_SEPARATOR:=   }"

_has() {
  command -v "$1" >/dev/null 2>&1
}

_bat_status() {
  status=""
  for b in /sys/class/power_supply/BAT*; do
    if [ -d "$b" ]; then
      while read -r line; do
        echo "$line"
        break
      done <"$b/status"
      break
    fi
  done
}

_bat_val() {
  col="$1"
  total=0
  batteries=0
  for battery in /sys/class/power_supply/BAT*; do
    if [ -r "$battery" ]; then
      while read -r line; do
        value="$line"
      done <"$battery/$col"
      total=$((value + total))
      batteries=$((batteries + 1))
    fi
  done
  [ "$batteries" -eq 0 ] && return
  echo "$((total / batteries))"
}

block_bat() {
  capacity="$(_bat_val capacity)"
  [ -z "$capacity" ] && echo "у°ҡҘ" && return 0

  # This is meant to be a constant string
  # shellcheck disable=2194
  case 1 in
  $((capacity >= 98))) icon="у°Ғ№" ;;
  $((capacity >= 90))) icon="у°ӮӮ" ;;
  $((capacity >= 80))) icon="у°ӮҒ" ;;
  $((capacity >= 70))) icon="у°ӮҖ" ;;
  $((capacity >= 60))) icon="у°Ғҝ" ;;
  $((capacity >= 50))) icon="у°Ғҫ" ;;
  $((capacity >= 40))) icon="у°ҒҪ" ;;
  $((capacity >= 30))) icon="у°Ғј" ;;
  $((capacity >= 20))) icon="у°Ғ»" ;;
  $((capacity >= 10))) icon="у°Ғә" ;;
  $((capacity >= 0))) icon="у°ӮҺ" ;;
  esac

  if [ "$(_bat_status)" = "Charging" ]; then
    case "$icon" in
    "у°Ғ№") icon="у°Ӯ…" ;;
    "у°ӮӮ") icon="у°ӮӢ" ;;
    "у°ӮҒ") icon="у°ӮҠ" ;;
    "у°ӮҖ") icon="у°ўһ" ;;
    "у°Ғҝ") icon="у°Ӯү" ;;
    "у°Ғҫ") icon="у°ўқ" ;;
    "у°ҒҪ") icon="у°ӮҲ" ;;
    "у°Ғј") icon="у°ӮҮ" ;;
    "у°Ғ»") icon="у°ӮҶ" ;;
    "у°Ғә") icon="у°ўң" ;;
    "у°ӮҺ") icon="у°ўҹ" ;;
    esac
  fi

  echo "$icon"
}

block_date() {
  fmt="$1"
  [ -z "$fmt" ] && fmt="%a %Y-%m-%d"
  echo "у°ғ® $(date "+$fmt")"
}

block_time() {
  fmt="$1"
  [ -z "$fmt" ] && fmt="%I:%M%p"
  echo "у°Ҙ” $(date "+$fmt")"
}

_volume_amixer_by_type() {
  type="$1"
  [ -z "$type" ] && return
  amixer get Master | while read -r line; do
    case "$line" in
    *Playback*%*on*)
      vol="${line%%"%]"*}"
      vol="${vol##*"["}"
      echo "$vol"
      break
      ;;
    esac
  done
}

_volume_amixer() {
  _volume_amixer_by_type "Master"
}

_volmic_amixer() {
  _volume_amixer_by_type "Capture"
}

_volume_pactl_by_type() {
  type="$1"
  [ -z "$type" ] && return
  pactl get-sink-volume "$type" | while read -r line; do
    case "$line" in
    "Volume"*)
      lvl="${line%%%*}"
      lvl="${lvl##* }"
      echo "$lvl"
      break
      ;;
    esac
  done
}

_volume_pactl() {
  _volume_pactl_by_type "@DEFAULT_SINK@"
}

_volmic_pactl() {
  _volume_pactl_by_type "@DEFAULT_CAPTURE@"
}

_volume_wpctl_by_type() {
  type="$1"
  [ -z "$type" ] && return
  wpctl get-volume "$type" | while read -r line; do
    case "$line" in
    "Volume: 1."*)
      lvl="${line##* }"
      echo "${lvl%%.*}${lvl##*.}"
      break
      ;;
    "Volume"*)
      lvl="${line##*.}"
      echo "${lvl#0}"
      break
      ;;
    esac
  done
}

_volume_wpctl() {
  _volume_wpctl_by_type "@DEFAULT_SINK@"
}

_volmic_wpctl() {
  _volume_wpctl_by_type "@DEFAULT_SOURCE@"
}

