block_cpu() {
  {
    head -n1 /proc/stat
    sleep 0.3
    head -n1 /proc/stat
  } | awk '/^cpu /{u=$2-u;s=$4-s;i=$5-i;w=$6-w}END{v=int(0.5+100*(u+s+w)/(u+s+i+w)); printf "п’ј %2d%%\n", (v>99?99:v)}'
}

block_ram() {
  free --mebi | sed -n '2{p;q}' | awk '{printf ("оүҰ %04.1fG", ( $3 / 1024), ($2 / 1024))}'
}

_keyboard_layout_xkbmap() {
  setxkbmap -query | while read -r line; do
    case "$line" in
    layout*)
      l="${line##* }"
      printf "у°ҢҢ %.2s" "$l"
      break
      ;;
    esac
  done
}

_keyboard_layout_swaymsg() {
  swaymsg -t get_inputs | while read -r line; do
    case "$line" in
    *"xkb_active_layout_name"*)
      l="${line##*"("}"
      l="${l%%")"*}"
      printf "у°ҢҢ %.2s" "$l" | tr '[:upper:]' '[:lower:]'
      break
      ;;
    esac
  done
}

block_keyboard() {
  if _has "setxkbmap"; then
    _keyboard_layout_xkbmap
    return
  fi

  # TODO: Check sway is running
  if _has "swaymsg"; then
    _keyboard_layout_swaymsg
    return
  fi

  # TODO: Add more backends
}

block_kb() {
  block_keyboard
}

block_net() {
  ethdown=""
  for eth in /sys/class/net/e*/operstate; do
    if [ -r "$eth" ]; then
      while read -r line; do
        case "$line" in
        up)
          # eth up
          echo "у°ӣі"
          return
          ;;
        down)
          ethdown=1
          ;;
        esac
      done <"$eth"
    fi
  done

  wup=""
  wdown=""
  for wint in /sys/class/net/w*/operstate; do
    if [ -r "$wint" ]; then
      while read -r line; do
        case "$line" in
        up)
          wup=1
          ;;
        down)
          wdown=1
          ;;
        esac
      done <"$wint"
    fi
  done

  if [ "$ethdown" ] && [ -z "$wdown" ] && [ -z "$wup" ]; then
    # eth down and no wireless interfaces
    echo "у°Іӣ" && return
  fi

  if [ -z "$wup" ]; then
    # no wireless interfaces are up
    echo "у°Ө®" && return
  fi

  # at least one wireless int is up, get strength
  strength="$(awk 'NR==3 {printf("%.0f\n",$3*10/7)}' /proc/net/wireless)"

  # This is meant to be a constant string
  # shellcheck disable=2194
  case 1 in
  $((strength >= 85))) icon="у°ӨЁ" ;;
  $((strength >= 65))) icon="у°ӨҘ" ;;
  $((strength >= 45))) icon="у°Өў" ;;
  $((strength >= 25))) icon="у°Өҹ" ;;
  $((strength >= 0))) icon="у°ӨҜ" ;;
  esac

  vpn=""
  for v in /sys/class/net/tun*/operstate /sys/class/net/wg*/operstate; do
    # a vpn is in use
    [ -r "$v" ] && vpn=1 && break
  done

  if [ "$vpn" ]; then
    case "$icon" in
    "у°ӨЁ") icon="у°ӨӘ" ;;
    "у°ӨҘ") icon="у°Ө§" ;;
    "у°Өў") icon="у°ӨӨ" ;;
    "у°Өҹ") icon="у°ӨЎ" ;;
    "у°ӨҜ") icon="у°Ө¬" ;;
    esac
  fi

  # resulting icon
  echo "$icon"
}

while true; do
  status=""
  for block in $SHTATUS_BLOCKS; do
    v="$(block_"$block" 2>/dev/null)"
    if [ "$v" ]; then
      case "$status" in
      "") status="$v" ;;
      *) status="$status$SHTATUS_SEPARATOR$v" ;;
      esac
    fi
  done

  echo "$status"

  [ "$1" ] && exit

  sleep "$SHTATUS_INTERVAL"
done
