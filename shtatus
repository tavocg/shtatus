block_net() {
  ethdown=""
  for eth in /sys/class/net/e*/operstate; do
    if [ -r "$eth" ]; then
      while read -r line; do
        case "$line" in
        up)
          # eth up
          echo "σΑ¦≥"
          return
          ;;
        down)
          ethdown=1
          ;;
        esac
      done <"$eth"
    fi
  done

  wup=""
  wdown=""
  for wint in /sys/class/net/w*/operstate; do
    if [ -r "$wint" ]; then
      while read -r line; do
        case "$line" in
        up)
          wup=1
          ;;
        down)
          wdown=1
          ;;
        esac
      done <"$wint"
    fi
  done

  if [ "$ethdown" ] && [ -z "$wdown" ] && [ -z "$wup" ]; then
    # eth down and no wireless interfaces
    echo "σΑ≤¦" && return
  fi

  if [ -z "$wup" ]; then
    # no wireless interfaces are up
    echo "σΑΛ°" && return
  fi

  # at least one wireless int is up, get strength
  strength="$(awk 'NR==3 {printf("%.0f\n",$3*10/7)}' /proc/net/wireless)"

  # This is meant to be a constant string
  # shellcheck disable=2194
  case 1 in
  $((strength >= 85))) icon="σΑΛ®" ;;
  $((strength >= 65))) icon="σΑΛΞ" ;;
  $((strength >= 45))) icon="σΑΛΔ" ;;
  $((strength >= 25))) icon="σΑΛü" ;;
  $((strength >= 0))) icon="σΑΛ·" ;;
  esac

  vpn=""
  for v in /sys/class/net/tun*/operstate /sys/class/net/wg*/operstate; do
    # a vpn is in use
    [ -r "$v" ] && vpn=1 && break
  done

  if [ "$vpn" ]; then
    case "$icon" in
    "σΑΛ®") icon="σΑΛΣ" ;;
    "σΑΛΞ") icon="σΑΛß" ;;
    "σΑΛΔ") icon="σΑΛΛ" ;;
    "σΑΛü") icon="σΑΛΓ" ;;
    "σΑΛ·") icon="σΑΛ§" ;;
    esac
  fi

  # resulting icon
  echo "$icon"
}

# taken from:
# https://github.com/eepykate/fet.sh
os=""
if [ -e /proc/$$/comm ]; then
  os="linux"
elif [ -f /var/run/dmesg.boot ]; then
  read -r bsd </var/run/dmesg.boot
  case $bsd in
  Open*) os="openbsd" ;;
  *) os="freebsd" ;;
  esac
fi

while true; do
  status=""
  for block in $SHTATUS_BLOCKS; do
    v="$(block_"$block" 2>/dev/null)"
    if [ "$v" ]; then
      case "$status" in
      "") status="$v" ;;
      *) status="$status$SHTATUS_SEPARATOR$v" ;;
      esac
    fi
  done

  echo "$status"

  [ "$1" ] && exit

  sleep "$SHTATUS_INTERVAL"
done
