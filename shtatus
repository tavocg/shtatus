_net_linux_strength() {
  line_no=0
  while IFS= read -r line; do
    line_no=$((line_no + 1))
    if [ "$line_no" -lt 3 ]; then
      continue
    fi

    set -- $line
    link="$3"
    if [ -z "$link" ]; then
      return
    fi

    link="${link%%.*}"
    echo $(((link * 10 + 3) / 7))
    return
  done </proc/net/wireless
}

_net_linux() {
  ethdown=""
  for eth in /sys/class/net/e*/operstate; do
    if [ -r "$eth" ]; then
      while read -r line; do
        case "$line" in
        up)
          # eth up
          echo "¾░ø│"
          return
          ;;
        down)
          ethdown=1
          ;;
        esac
      done <"$eth"
    fi
  done

  wup=""
  wdown=""
  for wint in /sys/class/net/w*/operstate; do
    if [ -r "$wint" ]; then
      while read -r line; do
        case "$line" in
        up)
          wup=1
          ;;
        down)
          wdown=1
          ;;
        esac
      done <"$wint"
    fi
  done

  if [ "$ethdown" ] && [ -z "$wdown" ] && [ -z "$wup" ]; then
    # eth down and no wireless interfaces
    echo "¾░▓ø" && return
  fi

  if [ -z "$wup" ]; then
    # no wireless interfaces are up
    echo "¾░ż«" && return
  fi

  # at least one wireless int is up, get strength
  strength="$(_net_linux_strength)"
  [ -n "$strength" ] || return

  # This is meant to be a constant string
  # shellcheck disable=2194
  case 1 in
  $((strength >= 85))) icon="¾░ż©" ;;
  $((strength >= 65))) icon="¾░żź" ;;
  $((strength >= 45))) icon="¾░żó" ;;
  $((strength >= 25))) icon="¾░ż¤" ;;
  $((strength >= 0))) icon="¾░ż»" ;;
  esac

  vpn=""
  for v in /sys/class/net/tun*/operstate /sys/class/net/wg*/operstate; do
    # a vpn is in use
    [ -r "$v" ] && vpn=1 && break
  done

  if [ "$vpn" ]; then
    case "$icon" in
    "¾░ż©") icon="¾░ż¬" ;;
    "¾░żź") icon="¾░ż¦" ;;
    "¾░żó") icon="¾░żż" ;;
    "¾░ż¤") icon="¾░żĪ" ;;
    "¾░ż»") icon="¾░ż¼" ;;
    esac
  fi

  # resulting icon
  echo "$icon"
}

block_net() {
  case "$os" in
  linux) _net_linux ;;
  esac
}

# taken from:
# https://github.com/eepykate/fet.sh
os=""
if [ -e /proc/$$/comm ]; then
  os="linux"
elif [ -f /var/run/dmesg.boot ]; then
  read -r bsd </var/run/dmesg.boot
  case $bsd in
  Open*) os="openbsd" ;;
  *) os="freebsd" ;;
  esac
fi

while true; do
  status=""
  for block in $SHTATUS_BLOCKS; do
    v="$(block_"$block" 2>/dev/null)"
    if [ "$v" ]; then
      case "$status" in
      "") status="$v" ;;
      *) status="$status$SHTATUS_SEPARATOR$v" ;;
      esac
    fi
  done

  echo "$status"

  [ "$1" ] && exit

  sleep "$SHTATUS_INTERVAL"
done
